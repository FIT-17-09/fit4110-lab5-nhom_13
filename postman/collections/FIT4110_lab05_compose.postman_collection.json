{
  "info": {
    "name": "FIT4110 Lab05 Compose Health Checks",
    "_postman_id": "fit4110-lab05-compose-health",
    "description": "Health checks for API and AI service in Docker Compose",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000"
    },
    {
      "key": "aiServiceUrl",
      "value": "http://localhost:9000"
    }
  ],
  "item": [
    {
      "name": "API Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('API health returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('API status is ok', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.status).to.eql('ok');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "AI Service Health",
      "request": {
        "method": "GET",
        "url": "{{aiServiceUrl}}/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('AI service health returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('AI service status is ok', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.status).to.eql('ok');",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
